# ─── Base de datos (Supabase / PostgreSQL) ─────────────────
DATABASE_URL="postgresql://postgres.[tu_proyecto]:[tu_password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ─── JWT Secret Key (OBLIGATORIO en producción) ────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="CAMBIAR_POR_UNA_CLAVE_SEGURA"

# ─── CORS Orígenes permitidos (separados por coma) ─────────
# En desarrollo: http://localhost:4200
# En producción: https://tu-dominio.com,https://www.tu-dominio.com
CORS_ORIGINS="http://localhost:4200,https://helpdesk-bpo.vercel.app"

# ─── Supabase Storage (para archivos adjuntos en la nube) ───
SUPABASE_URL="https://TU_PROYECTO.supabase.co"
SUPABASE_KEY="tu_anon_key_aqui"
